<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%@ taglib uri="http://java.sun.com/jsp/jstl/core" prefix="c" %>
<%@ taglib uri="http://java.sun.com/jsp/jstl/functions" prefix="fn" %>
<c:set var="ctx" value="${pageContext.request.contextPath}" />
<c:set var="uri" value="${pageContext.request.requestURI}" />

<style>
.nav-link--admin {
    background: linear-gradient(110deg, rgba(232, 164, 184, 0.16), rgba(196, 181, 253, 0.12)) !important;
    border: 1px solid rgba(232, 164, 184, 0.38) !important;
    color: var(--text) !important;
}
.nav-link--admin:hover {
    background: linear-gradient(110deg, rgba(232, 164, 184, 0.26), rgba(196, 181, 253, 0.18)) !important;
    border-color: rgba(232, 164, 184, 0.5) !important;
    box-shadow: 0 4px 16px rgba(232, 164, 184, 0.15);
}

.nav-link .nav-txt {
    position: relative;
    display: inline-grid;
    align-items: center;
}
.nav-link .nav-txt__en,
.nav-link .nav-txt__ko {
    grid-area: 1 / 1;
    transition: opacity 120ms ease;
}
.nav-link .nav-txt__en { opacity: 1; }
.nav-link .nav-txt__ko { opacity: 0; }
.nav-link:hover .nav-txt__en { opacity: 0; }
.nav-link:hover .nav-txt__ko { opacity: 1; }

.nav-global-search {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    height: 36px;
    width: 36px;
    padding: 0;
    border-radius: 999px;
    border: 1px solid rgba(232, 164, 184, 0.24);
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 8px 20px rgba(28, 25, 23, 0.08);
    justify-content: flex-end;
    overflow: hidden;
    transition: width .28s ease, padding .28s ease, border-color .2s ease, box-shadow .2s ease;
}
.nav-global-search:focus-within {
    border-color: rgba(232, 164, 184, 0.48);
    box-shadow: 0 10px 24px rgba(232, 164, 184, 0.16);
}
.nav-global-search.is-open {
    width: 220px;
    padding: 0 6px 0 10px;
}
.nav-global-search__input {
    width: 0;
    min-width: 0;
    border: 0;
    outline: 0;
    background: transparent;
    font-size: 12px;
    font-weight: 600;
    color: rgba(28, 25, 23, 0.88);
    opacity: 0;
    transform: translateX(10px);
    pointer-events: none;
    transition: width .28s ease, opacity .2s ease, transform .28s ease;
}
.nav-global-search.is-open .nav-global-search__input {
    width: 170px;
    opacity: 1;
    transform: translateX(0);
    pointer-events: auto;
}
.nav-global-search__input::placeholder {
    color: rgba(120, 113, 108, 0.66);
}
.nav-global-search__btn {
    width: 26px;
    height: 26px;
    border: 0;
    border-radius: 999px;
    cursor: pointer;
    color: #fff;
    background: linear-gradient(135deg, rgba(232, 164, 184, 0.95), rgba(196, 181, 253, 0.95));
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform .15s ease, box-shadow .2s ease;
}
.nav-global-search__btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 16px rgba(232, 164, 184, 0.25);
}
.nav-global-search--dock {
    position: fixed;
    top: calc((var(--nav-h, 68px) - 36px) / 2);
    right: 72px;
    z-index: 10066;
}
@media (max-width: 768px) {
    .nav-global-search--dock {
        right: 56px;
    }
    .nav-global-search.is-open {
        width: 190px;
    }
    .nav-global-search.is-open .nav-global-search__input {
        width: 140px;
    }
}

.fanmap-modal{position:fixed;inset:0;z-index:10070;display:none;align-items:center;justify-content:center;padding:24px;}
.fanmap-modal.is-open{display:flex;}
.fanmap-modal__dim{position:absolute;inset:0;background:rgba(28,25,23,.32);backdrop-filter:blur(10px);}
.fanmap-modal__panel{position:relative;width:min(980px,calc(100vw - 48px));height:min(720px,calc(100vh - 48px));
  border-radius:18px;overflow:hidden;
  background:linear-gradient(180deg,rgba(255,255,255,.96),rgba(255,250,252,.92));
  border:1px solid rgba(232,164,184,.22);
  box-shadow:0 28px 80px rgba(28,25,23,.12);
}
.fanmap-modal__head{position:absolute;left:0;right:0;top:0;z-index:5;
  display:flex;align-items:center;gap:12px;justify-content:space-between;
  padding:14px 16px;
  background:linear-gradient(180deg,rgba(255,255,255,.94),rgba(255,255,255,.72));
  border-bottom:1px solid rgba(232,164,184,.18);
}
.fanmap-title{display:flex;align-items:center;gap:10px;font-family:"Orbitron",sans-serif;font-size:11px;letter-spacing:.16em;color:rgba(28,25,23,.9);}
.fanmap-sub{font-family:"Noto Sans KR",sans-serif;font-size:12px;font-weight:600;color:rgba(68,64,60,.82);letter-spacing:.02em;}
.fanmap-back{height:34px;padding:0 12px;border-radius:12px;border:1px solid rgba(232,164,184,.22);
  background:rgba(255,255,255,.9);cursor:pointer;color:rgba(28,25,23,.82);
  display:none;align-items:center;gap:8px;font-weight:800;font-size:12px;
}
.fanmap-back:hover{transform:translateY(-1px);box-shadow:0 8px 22px rgba(232,164,184,.14);}
.fanmap-back.is-on{display:inline-flex;}
.fanmap-close{width:36px;height:36px;border-radius:12px;border:1px solid rgba(232,164,184,.22);
  background:rgba(255,255,255,.9);cursor:pointer;color:rgba(28,25,23,.8);
  display:inline-flex;align-items:center;justify-content:center;transition:transform .18s ease, box-shadow .18s ease;
}
.fanmap-close:hover{transform:translateY(-1px);box-shadow:0 8px 22px rgba(232,164,184,.14);}
.fanmap-canvas{position:absolute;inset:54px 0 0 0;}
.fanmap-tools{display:flex;align-items:center;gap:10px;margin-top:8px;flex-wrap:wrap}
.fanmap-tools .chip{height:30px;padding:0 12px;border-radius:999px;border:1px solid rgba(232,164,184,.22);
  background:rgba(255,255,255,.85);cursor:pointer;color:rgba(28,25,23,.82);font-weight:800;font-size:12px;
}
.fanmap-tools .chip.is-on{background:linear-gradient(135deg,rgba(232,164,184,.2),rgba(196,181,253,.14));border-color:rgba(232,164,184,.35);}
.fanmap-tools input,.fanmap-tools select{height:30px;border-radius:999px;border:1px solid rgba(232,164,184,.22);
  background:rgba(255,255,255,.85);padding:0 12px;font-weight:700;font-size:12px;outline:none;
}
.fanmap-split{position:absolute;top:54px;bottom:0;right:0;width:300px;border-left:1px solid rgba(232,164,184,.16);
  background:linear-gradient(180deg,rgba(255,255,255,.72),rgba(253,242,245,.55));
}
.fanmap-canvas{right:300px;}
.fanmap-side{height:100%;padding:14px 14px 12px;overflow:auto}
.fanmap-kpi{display:grid;grid-template-columns:1fr;gap:10px;margin-top:10px}
.fanmap-kpi .k{border-radius:16px;border:1px solid rgba(232,164,184,.18);background:rgba(255,255,255,.82);padding:12px}
.fanmap-kpi .k .t{font-family:"Orbitron",sans-serif;font-size:10px;letter-spacing:.16em;color:rgba(68,64,60,.72)}
.fanmap-kpi .k .v{margin-top:6px;font-size:20px;font-weight:900;color:rgba(28,25,23,.92)}
.fanmap-kpi .k .v.num-rise{ animation:fanNumRise .45s cubic-bezier(.23,1.2,.46,.98); }
@keyframes fanNumRise{ from{opacity:.08;transform:translateY(14px);} to{opacity:1;transform:translateY(0);} }
.fanmap-top{margin-top:12px;border-radius:16px;border:1px solid rgba(232,164,184,.18);background:rgba(255,255,255,.82);padding:12px}
.fanmap-top .row{display:flex;align-items:center;justify-content:space-between;padding:6px 0;border-bottom:1px solid rgba(232,164,184,.12)}
.fanmap-top .row:last-child{border-bottom:0}
.fanmap-top .nm{font-weight:900}
.fanmap-top .ct{font-family:"Orbitron",sans-serif;font-weight:900}
@media (max-width: 980px){ .fanmap-split{display:none;} .fanmap-canvas{right:0;} }
.fan-pin{border-radius:999px;display:flex;flex-direction:column;align-items:center;justify-content:center;
  box-shadow:0 12px 32px rgba(28,25,23,.08);
  backdrop-filter:blur(14px) saturate(1.05);
  -webkit-backdrop-filter:blur(14px) saturate(1.05);
  color:rgba(28,25,23,.9);
}
.fan-pin__name{font-family:"Orbitron",sans-serif;font-size:10px;font-weight:900;letter-spacing:.1em;line-height:1;}
.fan-pin__count{margin-top:3px;font-family:"Noto Sans KR",sans-serif;font-size:11px;font-weight:800;line-height:1;}
</style>

