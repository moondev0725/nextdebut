        <div class="flex items-center shrink-0 mr-8">
            <a href="${ctx}/main" class="nav-brand" aria-label="NEXT DEBUT 홈">
                <img src="${ctx}/images/nextdebut-logo.png?v=20260421b" alt="NEXT DEBUT" width="1024" height="431" decoding="async" />
            </a>
        </div>

        <div class="hidden lg:flex flex-1 justify-center">
            <ul class="flex items-center gap-5 font-semibold text-sm tracking-wide">
                <li>
                    <a href="${ctx}/boards/notice" class="nav-link ${fn:contains(uri, '/boards/notice') ? 'nav-link--active' : ''}">
                        <i class="fas fa-bullhorn"></i>
                        <span class="nav-txt"><span class="nav-txt__en">NOTICE</span><span class="nav-txt__ko">공지</span></span>
                    </a>
                </li>
                <li>
                    <a href="${ctx}/guide" class="nav-link ${fn:contains(uri, '/guide') ? 'nav-link--active' : ''}">
                        <i class="fas fa-circle-info"></i>
                        <span class="nav-txt"><span class="nav-txt__en">GUIDE</span><span class="nav-txt__ko">가이드</span></span>
                    </a>
                </li>
                <li>
                    <a href="${ctx}/trainees" class="nav-link ${fn:contains(uri, '/trainees') ? 'nav-link--active' : ''}">
                        <i class="fas fa-book-open"></i>
                        <span class="nav-txt"><span class="nav-txt__en">INDEX</span><span class="nav-txt__ko">도감</span></span>
                    </a>
                </li>
                <li>
                    <a href="${ctx}/boards/free" class="nav-link ${fn:contains(uri, '/boards/free') or fn:contains(uri, '/boards/lounge') or fn:contains(uri, '/boards/guide') ? 'nav-link--active' : ''}">
                        <i class="fas fa-comments"></i>
                        <span class="nav-txt"><span class="nav-txt__en">BOARD</span><span class="nav-txt__ko">게시판</span></span>
                    </a>
                </li>
                <li>
                    <a href="${ctx}/boards/fanmeeting" class="nav-link ${fn:contains(uri, '/boards/fanmeeting') ? 'nav-link--active' : ''}">
                        <i class="fas fa-heart"></i>
                        <span class="nav-txt"><span class="nav-txt__en">FANMEETING</span><span class="nav-txt__ko">팬미팅</span></span>
                    </a>
                </li>
                <li>
                    <a href="${ctx}/boards/map" class="nav-link ${fn:contains(uri, '/boards/map') ? 'nav-link--active' : ''}">
                        <i class="fas fa-map-location-dot"></i>
                        <span class="nav-txt"><span class="nav-txt__en">CASTING</span><span class="nav-txt__ko">길거리 캐스팅</span></span>
                    </a>
                </li>
                <li>
                    <a href="${ctx}/boards/report" class="nav-link ${fn:contains(uri, '/boards/report') ? 'nav-link--active' : ''}">
                        <i class="fas fa-bug"></i>
                        <span class="nav-txt"><span class="nav-txt__en">REPORT</span><span class="nav-txt__ko">신고</span></span>
                    </a>
                </li>
                <li>
                    <a href="${ctx}/market/shop" class="nav-link ${fn:contains(uri, '/market/shop') or fn:contains(uri, '/market/gacha') ? 'nav-link--active' : ''}">
                        <i class="fas fa-gift"></i>
                        <span class="nav-txt"><span class="nav-txt__en">SHOP</span><span class="nav-txt__ko">상점/뽑기</span></span>
                    </a>
                </li>
            </ul>
        </div>

        <%-- lg 이상에서만 보이면 태블릿·모바일에서 경험치 바가 안 보임 → 게임 등에서 항상 표시 --%>
        <div class="flex items-center justify-end shrink-0 gap-1 sm:gap-2 md:gap-3 ml-2 sm:ml-4 md:ml-5 min-w-0">
            <c:choose>
                <c:when test="${not empty sessionScope.LOGIN_MEMBER}">
                    <div class="flex items-center gap-3 flex-nowrap">
                        <div class="nav-user-block<c:if test="${not empty memberRankLabel and not empty memberRankCode}"> member-rank-tier member-rank-tier--<c:out value="${memberRankCode}"/></c:if>">
                        <a href="${ctx}/mypage" class="mypage-trigger mypage-trigger--stacked" aria-label="마이페이지로 이동">
                            <div class="mypage-trigger__row">
                                <span class="mypage-trigger__avatar"><i class="fas fa-user"></i></span>
                                <c:if test="${not empty memberRankLabel}">
                                    <span class="member-rank-pill" title="누적 등급 경험치 ${memberRankExp}"><c:out value="${memberRankLabel}"/></span>
                                </c:if>
                                <span class="mypage-trigger__name"><c:out value="${empty sessionScope.LOGIN_MEMBER.nickname ? sessionScope.LOGIN_MEMBER.mname : sessionScope.LOGIN_MEMBER.nickname}"/></span>
                                <i class="fas fa-chevron-down mypage-trigger__chevron"></i>
                            </div>
                            <c:if test="${not empty memberRankLabel}">
                                <c:choose>
                                    <c:when test="${navRankGainAnim}">
                                        <c:set var="barPct" value="${empty navRankBarFromPct ? 0 : navRankBarFromPct}" />
                                    </c:when>
                                    <c:otherwise>
                                        <c:set var="barPct" value="${empty memberRankBarPercent ? 0 : memberRankBarPercent}" />
                                    </c:otherwise>
                                </c:choose>
                                <div class="member-rank-expbar-wrap"
                                     title="누적 ${memberRankExp} EXP<c:if test="${not memberRankMaxTier and not empty memberRankNextLabel}"> · 다음 <c:out value="${memberRankNextLabel}"/>까지 <c:out value="${memberRankExpUntilNext}"/> EXP</c:if>">
                                    <c:if test="${navRankGainAnim}">
                                        <div id="navMemberRankExpLine" class="member-rank-exp-line" aria-hidden="true">
                                            <span id="navMemberRankExpTicker" class="member-rank-exp-line__n">${navRankExpFrom}</span><span class="member-rank-exp-line__s"> EXP</span>
                                        </div>
                                    </c:if>
                                    <div class="member-rank-expbar" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="${barPct}" aria-label="다음 등급까지 경험치">
                                        <div id="navMemberRankExpFill" class="member-rank-expbar__fill" style="width: ${barPct}%;"></div>
                                    </div>
                                    <div class="member-rank-expbar__meta">
                                        <c:choose>
                                            <c:when test="${memberRankMaxTier}"><span>MAX</span></c:when>
                                            <c:otherwise><span class="member-rank-expbar__next">NEXT <c:out value="${memberRankNextLabel}"/></span><span class="member-rank-expbar__gap"><c:out value="${memberRankExpUntilNext}"/> EXP</span></c:otherwise>
                                        </c:choose>
                                    </div>
                                </div>
                            </c:if>
                        </a>
                        </div>
                        <form action="${ctx}/logout" method="post" class="m-0 shrink-0">
                            <button type="submit" class="nav-link nav-link--compact whitespace-nowrap text-sm">
                                <i class="fas fa-right-from-bracket"></i>LOG OUT
                            </button>
                        </form>
                        <c:if test="${sessionScope.LOGIN_MEMBER.role eq 'ADMIN'}">
                            <a href="${ctx}/admin" class="nav-link nav-link--compact nav-link--admin whitespace-nowrap text-sm">
                                <i class="fas fa-gauge-high"></i>ADMIN
                            </a>
                        </c:if>
                    </div>
                </c:when>
                <c:otherwise>
                    <div class="flex items-center gap-3 flex-nowrap">
                        <a href="${ctx}/login" class="nav-link nav-link--compact text-sm ${fn:contains(uri, '/login')  ? 'nav-link--active' : ''}">LOG IN</a>
                        <a href="${ctx}/signup" class="nav-link nav-link--compact text-sm ${fn:contains(uri, '/signup') ? 'nav-link--active' : ''}">SIGN UP</a>
                    </div>
                </c:otherwise>
            </c:choose>

        </div>

    </div>
</nav>

<c:if test="${navRankGainAnim}">
<script>
window.__NAV_RANK_GAIN__ = {
  fromPct: ${empty navRankBarFromPct ? 0 : navRankBarFromPct},
  toPct: ${empty navRankBarToPct ? 0 : navRankBarToPct},
  fromExp: ${empty navRankExpFrom ? 0 : navRankExpFrom},
  toExp: ${empty navRankExpTo ? 0 : navRankExpTo},
  delta: ${empty navRankExpDeltaUi ? 0 : navRankExpDeltaUi}
};
</script>
<script defer src="${ctx}/js/nav-rank-gain.js"></script>
</c:if>

<%@ include file="/WEB-INF/views/fragments/right-side-nav.jspf" %>

<button type="button" class="game-bgm-toggle" id="gameBgmToggleBtn" aria-label="배경음악 열기" title="배경음악"><i class="fas fa-music"></i></button>
<form method="get" action="${ctx}/boards/search" class="nav-global-search nav-global-search--dock hidden lg:inline-flex" role="search" aria-label="통합검색">
    <input type="hidden" name="scope" value="all" />
    <input type="search" name="q" class="nav-global-search__input" placeholder="통합검색" value="<c:out value='${param.q}'/>" autocomplete="off" />
    <button type="submit" class="nav-global-search__btn" aria-label="검색">
        <i class="fas fa-magnifying-glass"></i>
    </button>
</form>
<div id="globalBgmSlot" class="unitx-bgm-dock"></div>

<script>
(function () {
    var form = document.querySelector('.nav-global-search');
    if (!form) return;

    var input = form.querySelector('.nav-global-search__input');
    var button = form.querySelector('.nav-global-search__btn');
    if (!input || !button) return;
    var openedAt = 0;

    function openSearch() {
        openedAt = Date.now();
        form.classList.add('is-open');
        requestAnimationFrame(function () {
            input.focus();
            if (input.value) {
                var len = input.value.length;
                input.setSelectionRange(len, len);
            }
        });
    }

    function closeSearch() {
        if ((input.value || '').trim()) return;
        form.classList.remove('is-open');
    }

    function isOpen() {
        return form.classList.contains('is-open');
    }

    if ((input.value || '').trim()) {
        form.classList.add('is-open');
    }

    button.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();

        if (!isOpen()) {
            openSearch();
            return;
        }

        if (!(input.value || '').trim()) {
            input.focus();
            return;
        }

        form.submit();
    });

    form.addEventListener('click', function (e) {
        e.stopPropagation();
    });

    input.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') {
            input.value = '';
            closeSearch();
            button.focus();
            return;
        }

        if (e.key === 'Enter') {
            e.preventDefault();
            if ((input.value || '').trim()) {
                form.submit();
            }
        }
    });

    document.addEventListener('pointerdown', function (e) {
        if (!isOpen()) return;
        if (Date.now() - openedAt < 250) return;
        if (!form.contains(e.target)) {
            closeSearch();
        }
    });
})();
</script>

<div class="fanmap-modal" id="fanMapModal" aria-hidden="true">
    <div class="fanmap-modal__dim" data-close-fan-map></div>
    <div class="fanmap-modal__panel" role="dialog" aria-modal="true" aria-label="팬 분포 지도">
        <div class="fanmap-modal__head">
            <div>
                <div class="fanmap-title"><i class="fas fa-map-location-dot"></i> FAN DISTRIBUTION MAP</div>
                <div class="fanmap-sub" id="fanMapScopeText">서울 구별 팬 수 (구 클릭 → 동 분포)</div>
                <div class="fanmap-tools">
                    <button type="button" class="chip is-on" data-range="7">7일</button>
                    <button type="button" class="chip" data-range="30">30일</button>
                    <button type="button" class="chip" data-range="0">전체</button>
                    <select id="fanMapTopN">
                        <option value="0">전체 보기</option>
                        <option value="10">Top 10</option>
                        <option value="20">Top 20</option>
                    </select>
                    <select id="fanMapHideZero">
                        <option value="true" selected>0명 숨김</option>
                        <option value="false">0명 포함</option>
                    </select>
                    <input id="fanMapSearch" placeholder="구/동 검색" />
                </div>
            </div>
            <div class="flex items-center gap-2">
                <button type="button" class="fanmap-back" id="fanMapBackBtn" onclick="window.__fanMapBackToGu && window.__fanMapBackToGu()">
                    <i class="fas fa-arrow-left"></i> 서울 전체
                </button>
                <button type="button" class="fanmap-close" aria-label="닫기" onclick="closeFanMapModal()">
                    <i class="fas fa-xmark"></i>
                </button>
            </div>
        </div>
        <div class="fanmap-canvas" id="fanMapCanvas" aria-label="지도"></div>
        <div class="fanmap-split" aria-hidden="true">
            <div class="fanmap-side">
                <div class="font-orbitron text-[10px] tracking-[0.18em] text-stone-500">DETAIL</div>
                <div class="mt-1.5 text-sm font-extrabold text-stone-800" id="fanMapDetailTitle">서울</div>
                <div class="fanmap-kpi">
                    <div class="k">
                        <div class="t">TOTAL FANS</div>
                        <div class="v" id="fanMapTotal">-</div>
                    </div>
                    <div class="k">
                        <div class="t">DELTA</div>
                        <div class="v" id="fanMapDelta">-</div>
                    </div>
                </div>
                <div class="fanmap-top">
                    <div class="font-orbitron text-[10px] tracking-[0.18em] text-stone-500 mb-1.5">TOP</div>
                    <div id="fanMapTopList"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<c:if test="${not empty sessionScope.LOGIN_MEMBER}">
<style>
.mypage-trigger {
    position: relative;
    z-index: 10;
    background: var(--card-strong, rgba(255,255,255,0.94));
    border: 1px solid var(--card-border, rgba(232,164,184,0.22));
    cursor: pointer;
    font-family: "Orbitron", sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--text-mid);
    display: flex;
    align-items: center;
    gap: 7px;
    white-space: nowrap;
    padding: 6px 12px 6px 7px;
    border-radius: 999px;
    transition: color 200ms ease, background 200ms ease, border-color 200ms ease, box-shadow 200ms ease, transform 200ms ease;
    overflow: hidden;
    text-decoration: none;
}
.mypage-trigger--stacked {
    flex-direction: column;
    align-items: stretch;
    gap: 3px;
    padding: 3px 8px 4px 7px;
    border-radius: 12px;
    white-space: normal;
    max-width: min(280px, min(42vw, calc(100vw - 200px)));
    min-width: 0;
    /* 기본 .mypage-trigger의 overflow:hidden이 경험치 줄·NEXT 문구를 잘라 레이아웃이 깨져 보임 */
    overflow: visible;
}
.mypage-trigger__row {
    display: flex;
    align-items: center;
    gap: 5px;
    white-space: nowrap;
    min-width: 0;
}
.mypage-trigger::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(110deg, rgba(232,164,184,0.12) 0%, rgba(196,181,253,0.08) 100%);
    opacity: 0;
    transition: opacity 220ms ease;
}
.mypage-trigger:hover {
    color: var(--text);
    border-color: rgba(232,164,184,0.4);
    box-shadow: 0 4px 16px rgba(232,164,184,0.12);
    transform: translateY(-1px);
}
.mypage-trigger:hover::before { opacity: 1; }
.mypage-trigger--stacked .mypage-trigger__avatar {
    width: 17px;
    height: 17px;
    font-size: 7px;
}
.mypage-trigger__avatar {
    position: relative;
    z-index: 1;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--ux-rose, #e8a4b8), var(--lv, #c4b5fd));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 8px;
    color: #fff;
    flex-shrink: 0;
}
.mypage-trigger--stacked .mypage-trigger__name {
    font-size: 11px;
    line-height: 1.15;
}
.mypage-trigger__name {
    position: relative;
    z-index: 1;
    font-family: "Noto Sans KR", "Apple SD Gothic Neo", sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.03em;
}
.mypage-trigger__chevron {
    position: relative;
    z-index: 1;
    font-size: 7px;
    opacity: 0.5;
    transition: transform 250ms ease, opacity 200ms ease;
}
.mypage-trigger:hover .mypage-trigger__chevron {
    transform: rotate(180deg);
    opacity: 0.85;
}
.mypage-trigger--stacked .mypage-trigger__chevron {
    font-size: 6px;
}
.mypage-trigger--stacked .member-rank-pill {
    padding: 1px 6px;
    font-size: 8px;
    max-width: 100px;
    letter-spacing: 0.04em;
}
.member-rank-pill {
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    max-width: 120px;
    overflow: hidden;
    text-overflow: ellipsis;
    padding: 2px 8px;
    border-radius: 999px;
    font-family: "Orbitron", sans-serif;
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.06em;
    color: rgba(91, 33, 182, 0.95);
    background: linear-gradient(135deg, rgba(196, 181, 253, 0.45), rgba(232, 164, 184, 0.35));
    border: 1px solid rgba(139, 92, 246, 0.35);
    line-height: 1.2;
}
.nav-user-block {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    min-width: 0;
    max-width: 100%;
    overflow: visible;
}
.member-rank-expbar-wrap {
    width: 100%;
    min-width: 0;
    max-width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1px;
}
.member-rank-expbar {
    height: 5px;
    border-radius: 999px;
    background: rgba(139, 92, 246, 0.16);
    border: 1px solid rgba(139, 92, 246, 0.35);
    overflow: hidden;
    box-shadow: inset 0 1px 2px rgba(255,255,255,0.45);
}
.member-rank-expbar__fill {
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, #a78bfa, #c4b5fd 45%, #f0abfc);
    transition: width 0.35s ease;
    min-width: 0;
    box-shadow: 0 0 10px rgba(139, 92, 246, 0.45), inset 0 0 0 1px rgba(255,255,255,0.22);
}
.member-rank-expbar__meta {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 4px;
    flex-wrap: nowrap;
    margin-top: 0;
    min-width: 0;
    width: 100%;
    overflow: hidden;
    font-family: "Orbitron", sans-serif;
    font-size: 7px;
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1.15;
    color: rgba(91, 33, 182, 0.75);
}
.member-rank-expbar__next {
    opacity: 0.88;
    flex: 1 1 auto;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}
.member-rank-expbar__gap { flex-shrink: 0; color: rgba(68, 64, 60, 0.65); font-weight: 800; white-space: nowrap; }
.member-rank-exp-line {
    text-align: right;
    margin-bottom: 0;
    font-family: "Orbitron", sans-serif;
    font-size: 7px;
    font-weight: 800;
    letter-spacing: 0.04em;
    line-height: 1.1;
    color: rgba(91, 33, 182, 0.92);
}
.member-rank-exp-line__n { font-variant-numeric: tabular-nums; }
.member-rank-exp-line__s { opacity: 0.75; font-weight: 700; margin-left: 2px; }
.member-rank-exp-line.flash-out {
    animation: navExpLineBlink 0.45s ease-in-out 3, navExpLineHide 0.55s ease 1.65s forwards;
}
@keyframes navExpLineBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.2; }
}
@keyframes navExpLineHide {
    to {
        opacity: 0;
        max-height: 0;
        margin-bottom: 0;
        overflow: hidden;
    }
}
.nav-rank-gain-pop {
    position: absolute;
    right: 0;
    top: -4px;
    transform: translateY(-100%);
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 3px;
    pointer-events: none;
    z-index: 30;
    animation: navRankPopIn 0.5s cubic-bezier(.23, 1, .32, 1) both;
}
.nav-rank-gain-pop.is-out { animation: navRankPopOut 0.55s ease forwards; }
.nav-rank-gain-pop__delta {
    font-family: "Orbitron", sans-serif;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.04em;
    color: #6d28d9;
    text-shadow: 0 0 18px rgba(124, 58, 237, 0.45);
}
.nav-rank-gain-pop__exp {
    font-family: "Orbitron", sans-serif;
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: rgba(68, 64, 60, 0.72);
}
@keyframes navRankPopIn {
    from { opacity: 0; transform: translateY(calc(-100% + 8px)) scale(0.96); }
    to { opacity: 1; transform: translateY(-100%) scale(1); }
}
@keyframes navRankPopOut {
    to { opacity: 0; transform: translateY(calc(-100% - 6px)); }
}
</style>
</c:if>

