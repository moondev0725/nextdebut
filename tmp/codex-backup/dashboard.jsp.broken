      if (coinDistEl && coinDistEl.parentElement) {
        coinDistEl.parentElement.innerHTML = '<div class="chart-placeholder">?뚯썝 肄붿씤 遺꾪룷 ?곗씠?곌? ?놁뒿?덈떎.</div>';
      }
      return;
    }
    if (coinDistChart) {
