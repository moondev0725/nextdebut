      </div>
    </div>
  </div>

  <section class="layout-main">
    <article class="card" id="members">
      <div class="section-head">?뚯썝 愿由?</div>
      <div class="section-body">
        <div class="chart-panel" style="margin-bottom:10px;">
          <div class="chart-title">?곕졊蹂??뚯썝 遺꾪룷</div>
          <div class="chart-canvas-wrap" style="min-height:190px;">
            <canvas id="chartMemberAge" aria-label="?곕졊蹂??뚯썝 遺꾪룷 李⑦듃"></canvas>
          </div>
        </div>
        <form method="get" action="${ctx}/admin" class="members-search">
          <input type="hidden" name="page" value="1"/>
          <input class="input" type="text" name="q" value="${q}" placeholder="아이디 / 이름 / 닉네임 / 이메일 검색" style="flex:1;min-width:220px;">
          <button class="btn" type="submit">寃??</button>
          <a class="btn" href="${ctx}/admin">珥덇린??</a>
          <span class="chip">${filteredMembersTotal} / ${allMembersTotal}</span>
        </form>
        <div class="members-table-wrap">
          <table class="members-table">
            <thead>
            <tr>
              <th>#</th><th>?뚯썝</th><th>ID</th><th>?대찓??</th><th>媛?낆씪</th><th>肄붿씤</th><th>?곗뒿??</th><th>?ы넗移대뱶</th><th>?곹깭</th><th>愿由?</th>
            </tr>
            </thead>
            <tbody>
            <c:choose>
              <c:when test="${empty allMembers}">
                <tr><td colspan="10"><div class="empty">寃??寃곌낵媛 ?놁뒿?덈떎.</div></td></tr>
              </c:when>
              <c:otherwise>
                <c:forEach var="m" items="${allMembers}" varStatus="vs">
                  <tr>
                    <td>${(memberPage - 1) * memberPageSize + vs.count}</td>
                    <td><span class="avatar">${fn:substring(empty m.nickname ? m.mname : m.nickname, 0, 1)}</span><c:out value="${empty m.nickname ? m.mname : m.nickname}"/></td>
                    <td><c:out value="${m.mid}"/></td>
                    <td><c:out value="${m.email}"/></td>
                    <td><c:out value="${m.createdAtStr}"/></td>
                    <td><fmt:formatNumber value="${memberOpsSummaryByMno[m.mno].coin}" pattern="#,##0"/></td>
                    <td><fmt:formatNumber value="${memberOpsSummaryByMno[m.mno].traineeCount}" pattern="#,##0"/>紐?</td>
                    <td><fmt:formatNumber value="${memberOpsSummaryByMno[m.mno].photoCardCount}" pattern="#,##0"/>??</td>
                    <td><span class="chip">${m.suspendedNow ? m.suspendRemainingDays : "?쒖꽦"}${m.suspendedNow ? "???뺤?" : ""}</span></td>
                    <td>
                      <div class="tools">
                        <button type="button" class="btn" onclick="openMemberDetail(${m.mno})">?곸꽭</button>
                        <button type="button" class="btn danger js-open-suspend" data-target="suspendForm-${m.mno}">?뺤?</button>
                        <form method="post" action="${ctx}/admin/members/${m.mno}/delete" style="margin:0;" onsubmit="return confirm('媛뺤젣 ?덊눜 泥섎━?좉퉴??');">
                          <button type="submit" class="btn danger">媛뺤젣 ?덊눜</button>
                        </form>
                      </div>
                      <form id="suspendForm-${m.mno}" method="post" action="${ctx}/admin/members/${m.mno}/suspend" style="display:none;margin-top:8px;gap:6px;align-items:center;flex-wrap:wrap;">
                        <input class="input" type="number" name="days" min="1" max="365" value="7" style="width:90px;">
                        <input class="input" type="text" name="reason" maxlength="255" placeholder="?뺤? ?ъ쑀(?좏깮)" style="min-width:160px;flex:1;">
                        <button type="submit" class="btn" style="font-size:12px;padding:7px 10px;">?곸슜</button>
                      </form>
                    </td>
                  </tr>
                </c:forEach>
              </c:otherwise>
            </c:choose>
            </tbody>
          </table>
        </div>
        <c:if test="${filteredMembersTotal > 0}">
          <div class="members-pager">
            <div class="info">
              <c:choose>
                <c:when test="${memberPageTotalPages > 1}">
                  ${memberPageRowFrom}??{memberPageRowTo}踰덉㎏ ?쒖떆 쨌 ?꾩껜 ${filteredMembersTotal}紐?쨌 ?섏씠吏 ${memberPage} / ${memberPageTotalPages}
                </c:when>
                <c:otherwise>
                  ?꾩껜 ${filteredMembersTotal}紐?                </c:otherwise>
              </c:choose>
            </div>
            <c:if test="${memberPageTotalPages > 1}">
              <div class="nav">
                <c:if test="${memberPage > 1}">
                  <c:url var="memberPageFirst" value="/admin"><c:param name="q" value="${q}"/><c:param name="page" value="1"/></c:url>
                  <a class="btn" href="${memberPageFirst}#members" title="泥??섏씠吏">짬 泥섏쓬</a>
                  <c:url var="memberPagePrev" value="/admin">
                    <c:param name="q" value="${q}"/>
                    <c:param name="page" value="${memberPage - 1}"/>
                  </c:url>
                  <a class="btn" href="${memberPagePrev}#members"><i class="fas fa-chevron-left"></i> ?댁쟾</a>
                </c:if>
                <c:forEach var="pi" items="${memberPageNumbers}">
                  <c:url var="memberPageUrl" value="/admin"><c:param name="q" value="${q}"/><c:param name="page" value="${pi}"/></c:url>
                  <c:choose>
                    <c:when test="${pi == memberPage}">
                      <span class="btn page-on" aria-current="page">${pi}</span>
                    </c:when>
                    <c:otherwise>
                      <a class="btn" href="${memberPageUrl}#members">${pi}</a>
                    </c:otherwise>
                  </c:choose>
                </c:forEach>
                <c:if test="${memberPage < memberPageTotalPages}">
                  <c:url var="memberPageNext" value="/admin">
                    <c:param name="q" value="${q}"/>
                    <c:param name="page" value="${memberPage + 1}"/>
                  </c:url>
                  <a class="btn" href="${memberPageNext}#members">?ㅼ쓬 <i class="fas fa-chevron-right"></i></a>
                  <c:url var="memberPageLast" value="/admin"><c:param name="q" value="${q}"/><c:param name="page" value="${memberPageTotalPages}"/></c:url>
                  <a class="btn" href="${memberPageLast}#members" title="留덉?留??섏씠吏">留덉?留?쨩</a>
                </c:if>
              </div>
            </c:if>
          </div>
        </c:if>
      </div>
    </article>

    <article class="card" id="game-admin">
      <div class="section-head">寃뚯엫 愿由?</div>
      <div class="section-body">
        <div class="ops-card" style="margin-bottom:12px;">
          <div class="ops-title">寃뚯엫 ?곗씠???붿빟</div>
          <div class="ops-metric">
            <div class="metric"><div class="k">珥?吏臾???</div><div class="v">${totalGameScenes}</div></div>
            <div class="metric"><div class="k">吏臾?phase ??</div><div class="v">${distinctScenePhases}</div></div>
            <div class="metric"><div class="k">珥??좏깮吏 ??</div><div class="v">${totalGameChoices}</div></div>
            <div class="metric"><div class="k">?좏깮吏 phase ??</div><div class="v">${distinctChoicePhases}</div></div>
            <div class="metric"><div class="k">?대깽??臾몄젣 ??</div><div class="v">${totalGameMiniQuizzes}</div></div>
            <div class="metric"><div class="k">?쒖꽦 ?대깽????</div><div class="v">${activeGameMiniQuizzes}</div></div>
          </div>
        </div>
        <div class="ops-card" style="margin-bottom:12px;">
          <div class="ops-title">梨꾪똿 ?좏깮 ML ?듦퀎</div>
          <div class="ops-metric">
            <div class="metric"><div class="k">珥??섑뵆</div><div class="v"><fmt:formatNumber value="${mlChoiceStats.total}" pattern="#,##0"/></div></div>
            <div class="metric"><div class="k">ML ?곸슜瑜?</div><div class="v"><fmt:formatNumber value="${mlChoiceStats.mlRate}" pattern="#,##0.0"/>%</div></div>
            <div class="metric"><div class="k">Fallback 鍮꾩쑉</div><div class="v"><fmt:formatNumber value="${mlChoiceStats.fallbackRate}" pattern="#,##0.0"/>%</div></div>
