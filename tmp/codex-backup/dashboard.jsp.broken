                  <div class="trainee-compact-name"><c:out value="${t.name}"/></div>
                  <div class="trainee-compact-meta">${t.gender eq 'MALE' ? '?⑥꽦' : '?ъ꽦'} 쨌 ?됯퇏 <fmt:formatNumber value="${sum div 5.0}" maxFractionDigits="1" /></div>
                  <div class="trainee-card-tags">
                    <span class="chip">R/SR/SSR 愿由?</span>
                  </div>
                </button>
              </c:forEach>
            </div>
            <div class="trainee-pager" id="traineePager"></div>
          </c:otherwise>
