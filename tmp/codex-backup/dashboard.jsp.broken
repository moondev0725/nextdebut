                return (ctx.label || '') + ': ' + ctx.parsed + '紐?;
              }
            }
          }
        }
      }
    });
  }

  renderCoinFlow('daily');
  bindPeriodTabs('coin-flow', renderCoinFlow);
  renderCoinDistribution('daily');
