                return '?뚯썝 ' + ctx.parsed.y + '紐?;
              }
            }
          }
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: {
              precision: 0,
              callback: function(v) { return v + '紐?; }
            }
          }
        }
      }
    });
  } else if (memberAgeEl && memberAgeEl.parentElement) {
    memberAgeEl.parentElement.innerHTML = '<div class="chart-placeholder">?곕졊 ?듦퀎 ?곗씠?곌? ?놁뒿?덈떎.</div>';
  }

  if (boardTrendEl && Array.isArray(BOARD_TREND_KEYS) && BOARD_TREND_KEYS.length > 0) {
    new Chart(boardTrendEl, {
      type: 'line',
