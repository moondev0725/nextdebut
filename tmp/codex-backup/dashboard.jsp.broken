              }
            }
          }
        },
        scales: {
          x: {
            title: { display: true, text: period === 'monthly' ? '?? : (period === 'weekly' ? '二쇨컙' : '?좎쭨') },
            ticks: { maxRotation: 40, minRotation: 0, autoSkip: true, maxTicksLimit: period === 'daily' ? 14 : 12 }
          },
